---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  badges: string[];
  cta: { text: string; href: string; variant: string }[];
}

const { eyebrow, title, subtitle, badges, cta } = Astro.props;
---

<section
  class="hero min-h-[92vh] flex items-center relative overflow-hidden py-25 pb-20"
>
  <div
    class="absolute inset-0 bg-linear-to-br from-coral/9 via-transparent to-transparent pointer-events-none"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(240,237,232,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(240,237,232,0.025) 1px, transparent 1px); background-size: 60px 60px;"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div
        class="inline-flex items-center gap-2 text-coral text-xs uppercase tracking-widest font-medium mb-6"
      >
        <span class="w-5 h-px bg-coral"></span>
        {eyebrow}
      </div>

      <h1
        class="text-5xl lg:text-6xl font-display font-bold text-offwhite mb-6 leading-tight"
      >
        {title}
        <em class="text-coral-light italic">ben feta</em>
      </h1>

      <p
        class="text-base lg:text-lg text-sand max-w-2xl mx-auto mb-10 leading-relaxed font-light"
      >
        {subtitle}
      </p>

      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {
          badges.map((badge) => (
            <span class="inline-flex items-center gap-2 bg-coral/15 border border-coral/3 rounded-full px-4 py-2 text-xs text-offwhite">
              <span class="w-1.5 h-1.5 rounded-full bg-coral animate-pulse" />
              {badge}
            </span>
          ))
        }
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {
          cta.map((item) => (
            <a
              href={item.href}
              class={`inline-flex items-center justify-center gap-2 px-8 py-4 rounded text-base font-medium transition-all ${
                item.variant === "primary"
                  ? "bg-coral text-white hover:bg-coral-light hover:-translate-y-0.5"
                  : "text-offwhite border border-white/10 hover:border-coral hover:text-coral"
              }`}
            >
              {item.text}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fadeUp 0.7s ease forwards;
    opacity: 0;
  }
  .animate-pulse {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.4);
      opacity: 0.6;
    }
  }
</style>
