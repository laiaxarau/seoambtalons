---
interface Step {
  num: string;
  title: string;
  description: string;
}

interface Props {
  header: { eyebrow: string; title: string; subtitle: string };
  steps: Step[];
}

const { header, steps } = Astro.props;
---

<section class="process bg-stone-900 py-20 lg:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 text-coral text-xs uppercase tracking-widest font-medium mb-6">
        <span class="w-5 h-px bg-coral"></span>
        {header.eyebrow}
      </div>
      <h2 class="text-4xl lg:text-5xl font-display font-bold text-offwhite mb-6">
        {header.title}
      </h2>
      <p class="text-base text-sand">{header.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
      <div class="absolute top-8 left-1/2 transform -translate-x-1/2 w-px h-px bg-coral/2 md:w-full md:h-px lg:w-px lg:h-full lg:top-0 lg:left-1/2"></div>
      {steps.map((step, index) => (
        <div class="step text-center relative">
          <div class="w-16 h-16 border border-white/10 bg-black rounded-full flex items-center justify-center mx-auto mb-6 text-coral font-display font-bold text-lg hover:border-coral transition-colors">
            {step.num}
          </div>
          <h3 class="text-lg font-medium text-offwhite mb-3">{step.title}</h3>
          <p class="text-sm text-sand leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>