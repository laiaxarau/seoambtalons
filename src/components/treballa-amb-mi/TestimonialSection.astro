---
interface Props {
  quote: string;
  author: { name: string; role: string; avatar: string };
}

const { quote, author } = Astro.props;
---

<section class="testimonial bg-black py-20 lg:py-32">
  <div class="container max-w-4xl mx-auto px-6">
    <div class="border border-white/10 rounded p-12 lg:p-16 relative">
      <div class="absolute -top-6 left-12 text-6xl text-coral/3 font-display">"</div>
      <blockquote class="text-xl lg:text-2xl font-display font-normal text-offwhite leading-relaxed italic mb-8">
        {quote}
      </blockquote>
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-coral/15 border border-coral/3 flex items-center justify-center text-coral font-display font-bold text-lg">
          {author.avatar}
        </div>
        <div>
          <div class="font-medium text-offwhite">{author.name}</div>
          <div class="text-sm text-stone-500">{author.role}</div>
        </div>
      </div>
    </div>
  </div>
</section>