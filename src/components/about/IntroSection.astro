---
interface Props {
  eyebrow: string;
  paragraphs: string[];
}

const { eyebrow, paragraphs } = Astro.props;
---

<section class="intro bg-stone-950 py-20 lg:py-32" id="la-meva-historia">
  <div class="max-w-3xl mx-auto px-6">
    <div
      class="inline-flex items-center gap-2 text-coral text-xs uppercase tracking-widest font-medium mb-8"
    >
      <span class="w-5 h-px bg-coral"></span>
      {eyebrow}
    </div>

    <div
      class="text-base lg:text-lg text-sand leading-relaxed space-y-6 font-light"
    >
      {
        paragraphs.map((para, idx) => {
          const isLastKey = idx === paragraphs.length - 1;
          return (
            <p class={isLastKey ? "italic font-display text-coral-light" : ""}>
              {para}
            </p>
          );
        })
      }
    </div>
  </div>
</section>
