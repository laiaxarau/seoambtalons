---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  cta: { text: string; href: string; variant: string }[];
}

const { eyebrow, title, subtitle, cta } = Astro.props;
---

<section class="final-cta py-24 lg:py-32 border-t border-white/10 relative">
  <div
    class="absolute inset-0 bg-linear-to-t from-coral/5 via-transparent pointer-events-none"
  >
  </div>
  <div class="max-w-2xl mx-auto px-6 relative z-10 text-center">
    <div
      class="inline-flex items-center gap-2 text-coral text-xs uppercase tracking-widest font-medium mb-8 justify-center"
    >
      <span class="w-5 h-px bg-coral"></span>
      {eyebrow}
      <span class="w-5 h-px bg-coral"></span>
    </div>

    <h2
      class="text-4xl lg:text-5xl font-display font-bold text-offwhite mb-6 leading-tight"
    >
      {title}
    </h2>

    <p
      class="text-base lg:text-lg text-sand mb-10 leading-relaxed font-light max-w-lg mx-auto"
    >
      {subtitle}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      {
        cta.map((item) => (
          <a
            href={item.href}
            class={`inline-flex items-center justify-center gap-2 px-8 py-4 rounded text-base font-medium transition-all ${
              item.variant === "primary"
                ? "bg-coral text-white hover:bg-coral-light hover:-translate-y-0.5"
                : "text-offwhite border border-white/10 hover:border-coral hover:text-coral"
            }`}
          >
            {item.text}
          </a>
        ))
      }
    </div>
  </div>
</section>
