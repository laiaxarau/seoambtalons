---
interface Valor {
  num: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  valors: Valor[];
}

const { eyebrow, title, intro, valors } = Astro.props;
---

<section class="valors bg-stone-900 py-20 lg:py-32">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <div
        class="inline-flex items-center gap-2 text-coral text-xs uppercase tracking-widest font-medium mb-6 justify-center"
      >
        <span class="w-5 h-px bg-coral"></span>
        {eyebrow}
        <span class="w-5 h-px bg-coral"></span>
      </div>
      <h2
        class="text-4xl lg:text-5xl font-display font-bold text-offwhite mb-4"
      >
        {title}
      </h2>
      <p class="text-base text-sand max-w-md mx-auto">
        {intro}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
      {
        valors.map((valor) => (
          <div class="bg-stone-900 px-8 py-12 md:py-16 relative overflow-hidden">
            <div class="absolute -bottom-2 -right-4 font-display text-7xl font-bold text-coral/8 pointer-events-none leading-tight">
              {valor.title}
            </div>
            <span class="text-xs uppercase tracking-widest text-coral font-medium block mb-4">
              {valor.num}
            </span>
            <h3 class="text-xl font-display font-bold text-offwhite mb-4">
              {valor.title}
            </h3>
            <p class="text-sm text-sand leading-relaxed relative">
              {valor.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
