---
import { siteConfig } from "../../config/site";
import { treballaFormats, treballaSchema } from "../../data/treballa-amb-mi";

const data = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: treballaSchema.name,
  provider: {
    "@type": "Person",
    name: siteConfig.author.name,
    url: siteConfig.url,
  },
  description: treballaSchema.description,
  url: `${siteConfig.url}/treballa-amb-mi`,
  areaServed: { "@type": "Country", name: "Espanya" },
  inLanguage: "ca",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: treballaSchema.catalogName,
    itemListElement: treballaFormats.formats.map((format) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: format.title,
      },
    })),
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "EUR",
    name: treballaSchema.offerName,
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
