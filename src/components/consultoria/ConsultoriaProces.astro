---
const steps = [
  {
    num: '1',
    title: 'Sessió de diagnosi gratuïta',
    desc: '30 min per conèixer el teu negoci, els teus objectius i els teus punts de millora SEO.',
  },
  {
    num: '2',
    title: 'Auditoria SEO completa',
    desc: 'Analitzem el teu web en profunditat: tècnica, contingut, paraules clau i competència.',
  },
  {
    num: '3',
    title: "Pla d'acció personalitzat",
    desc: 'Rebs un document clar amb prioritats, accions concretes i terminis realistes.',
  },
  {
    num: '4',
    title: 'Implementació i seguiment',
    desc: "T'acompanyo durant l'execució i fem seguiment mensual dels resultats.",
  },
]
---

<section class="px-8 lg:px-16 py-24">
  <div class="max-w-5xl mx-auto">

    <!-- Capçalera centrada -->
    <div class="text-center mb-20">
      <p class="eyebrow justify-center mb-4">Com funciona</p>
      <h2 class="font-display text-4xl lg:text-5xl font-black text-offwhite
                 leading-tight mb-5">
        El procés, pas a pas
      </h2>
      <p class="text-sand font-light max-w-lg mx-auto">
        Simple, clar i sense sorpreses. Saps en tot moment on som i on anem.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">

      <!-- Línia horitzontal — només desktop -->
      <div class="hidden lg:block absolute top-[2.25rem] left-[calc(12.5%+1.5rem)]
                  right-[calc(12.5%+1.5rem)] h-px bg-white/10"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {steps.map(({ num, title, desc }) => (
          <div class="flex flex-col items-center lg:items-start text-center
                      lg:text-left">

            <!-- Cercle número -->
            <div class="w-12 h-12 rounded-full bg-[#1a1612] border border-coral/30
                        flex items-center justify-center shrink-0 mb-6 relative z-10">
              <span class="font-display text-lg font-black text-coral">{num}</span>
            </div>

            <h3 class="text-offwhite font-medium text-base mb-3">{title}</h3>
            <p class="text-sand text-sm font-light leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>