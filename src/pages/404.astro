---
// src/pages/404.astro
import { notFoundPage } from "../data/not-found";
---

<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{notFoundPage.pageTitle}</title>
  </head>
  <body>
    <section class="page-404">
      <!-- Decoració fons -->
      <div class="bg-blob"></div>
      <div class="bg-grid"></div>

      <!-- Contingut -->
      <div class="content">
        <!-- Tag superior -->
        <span class="tag">
          <span class="tag-line"></span>
          {notFoundPage.eyebrow}
        </span>

        <!-- Número gran decoratiu -->
        <div class="big-number" aria-hidden="true">{notFoundPage.code}</div>

        <!-- Títol -->
        <h1 class="title">
          {notFoundPage.titleLines[0]}<br />
          {notFoundPage.titleLines[1]}
          <em>{notFoundPage.titleAccent}</em>
        </h1>

        <!-- Subtítol -->
        <p class="subtitle">
          {notFoundPage.subtitle}
        </p>

        <!-- CTA -->
        <a href={notFoundPage.cta.href} class="btn-primary">
          {notFoundPage.cta.label}
        </a>
      </div>

      <!-- Scroll indicator (igual que al hero) -->
      <div class="scroll-indicator">
        <div class="scroll-line">
          <div class="scroll-line-inner"></div>
        </div>
        {notFoundPage.scrollLabel}
      </div>
    </section>
  </body>
</html>

<style>
  /* ── Variables (han de coincidir amb el teu globals.css) ── */
  :root {
    --coral: #e8614a;
    --offwhite: #f5f0e8;
    --sand: #b8a99a;
    --dark: #111010;
    --dark-sand: #1a1714;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background: var(--dark);
    color: var(--offwhite);
    font-family: inherit;
    overflow: hidden;
  }

  /* ── Layout ── */
  .page-404 {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
  }

  /* ── Fons decoratiu ── */
  .bg-blob {
    position: absolute;
    top: 50%;
    right: -10%;
    transform: translateY(-50%);
    width: 500px;
    height: 500px;
    background: rgba(232, 97, 74, 0.12);
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  /* ── Contingut ── */
  .content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 640px;
  }

  /* Tag */
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--coral);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 500;
    margin-bottom: 2rem;
    animation: fadeUp 0.8s 0.1s ease forwards;
    opacity: 0;
  }

  .tag-line {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--coral);
  }

  /* Número gran */
  .big-number {
    position: absolute;
    top: 50%;
    left: -1rem;
    transform: translateY(-60%);
    font-size: clamp(8rem, 20vw, 16rem);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
    animation: fadeUp 0.8s 0.2s ease forwards;
    opacity: 0;
  }

  /* Títol */
  .title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--offwhite);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s 0.3s ease forwards;
    opacity: 0;
  }

  .title em {
    font-style: italic;
    color: var(--coral);
  }

  /* Subtítol */
  .subtitle {
    color: var(--sand);
    font-weight: 300;
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.5s ease forwards;
    opacity: 0;
  }

  /* Botó (igual que btn-primary del teu projecte) */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--coral);
    color: white;
    text-decoration: none;
    padding: 0.875rem 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
    animation: fadeUp 0.8s 0.7s ease forwards;
    opacity: 0;
  }

  .btn-primary:hover {
    background: #d4503a;
    transform: translateY(-2px);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(184, 169, 154, 0.4);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .scroll-line {
    width: 1px;
    height: 2.5rem;
    background: rgba(184, 169, 154, 0.2);
    position: relative;
    overflow: hidden;
  }

  .scroll-line-inner {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    background: var(--coral);
    animation: scrollLine 2s ease infinite;
  }

  /* ── Animacions ── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollLine {
    0% {
      height: 0;
      top: 0;
    }
    50% {
      height: 100%;
      top: 0;
    }
    100% {
      height: 0;
      top: 100%;
    }
  }
</style>
