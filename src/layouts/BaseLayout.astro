---
import SEOHead from '../components/seo/SEOHead.astro'
import Nav from './Nav.astro'
import Footer from './Footer.astro'
import CookieBanner from './CookieBanner.astro'
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
}

const { title, description, canonical, ogImage } = Astro.props
---

<!doctype html>
<html lang="ca">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />
  </head>
  <body class="bg-[#0a0a0a] text-offwhite font-body antialiased">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <!-- Botó flotant cookies -->
