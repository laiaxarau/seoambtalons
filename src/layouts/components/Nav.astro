---
import { navigationConfig } from "../../config/navigation";

const { main: navLinks } = navigationConfig;
const currentPath = Astro.url.pathname;
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between
         px-8 lg:px-16 py-5 transition-all duration-300"
>
  <!-- Logo -->
  <a href="/" class="font-display text-lg tracking-wide text-offwhite">
    SEO<span class="text-coral">amb</span>Talons
  </a>

  <!-- Links desktop -->
  <nav class="hidden lg:flex items-center gap-10">
    {
      navLinks.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            "text-xs uppercase tracking-widest transition-colors duration-200",
            currentPath.startsWith(href)
              ? "text-offwhite"
              : "text-sand hover:text-offwhite",
          ]}
        >
          {label}
        </a>
      ))
    }
  </nav>

  <!-- CTA + hamburger -->
  <div
    class="text-xs uppercase tracking-widest transition-colors duration-200 flex items-center gap-4"
  >
    <!-- <a
      href="/contacte"
      class="hidden lg:inline-block btn-primary !py-2.5 !px-6"
    >
      Parlem
    </a> -->

    <!-- Hamburger mòbil -->
    <button
      id="menu-toggle"
      class="lg:hidden flex flex-col gap-1.5 p-2"
      aria-label="Obrir menú"
    >
      <span
        class="hamburger-line block w-6 h-px bg-offwhite transition-all duration-300"
      ></span>
      <span
        class="hamburger-line block w-6 h-px bg-offwhite transition-all duration-300"
      ></span>
      <span
        class="hamburger-line block w-4 h-px bg-offwhite transition-all duration-300"
      ></span>
    </button>
  </div>
</header>

<!-- Menú mòbil -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-black/95 backdrop-blur-sm flex flex-col
         items-center justify-center gap-8 translate-x-full transition-transform
         duration-500 lg:hidden"
>
  {
    navLinks.map(({ label, href }) => (
      <a
        href={href}
        class="font-display text-3xl italic text-offwhite hover:text-coral
             transition-colors duration-200"
      >
        {label}
      </a>
    ))
  }
  <!-- <a href="/contacte" class="btn-primary mt-4">Parlem</a> -->
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const nav = document.getElementById("nav");
  const lines = document.querySelectorAll(".hamburger-line");

  // Menú mòbil
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("translate-x-0");

    menu?.classList.toggle("translate-x-full", isOpen);
    menu?.classList.toggle("translate-x-0", !isOpen);

    // Animació hamburger → X
    if (!isOpen) {
      lines[0]?.classList.add("rotate-45", "translate-y-2");
      lines[1]?.classList.add("opacity-0");
      lines[2]?.classList.add("-rotate-45", "-translate-y-2", "!w-6");
    } else {
      lines[0]?.classList.remove("rotate-45", "translate-y-2");
      lines[1]?.classList.remove("opacity-0");
      lines[2]?.classList.remove("-rotate-45", "-translate-y-2", "!w-6");
    }
  });

  // Fons nav en scroll
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add(
        "bg-black/90",
        "backdrop-blur-md",
        "border-b",
        "border-white/5",
      );
    } else {
      nav?.classList.remove(
        "bg-black/90",
        "backdrop-blur-md",
        "border-b",
        "border-white/5",
      );
    }
  });
</script>
